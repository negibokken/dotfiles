{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_AUTO_CONNECT_IDE": "false",
    "CLAUDE_CODE_IDE_SKIP_VALID_CHECK": "true",
    "CLAUDE_CODE_IDE_SKIP_AUTO_INSTALL": "true",
    "CLAUDE_CODE_ENABLE_TELEMETRY": "false",
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "true",
    "DISABLE_ERROR_REPORTING": "true",
    "DISABLE_TELEMETRY": "true",
    "DISABLE_AUTOUPDATER": "true",
    "DISABLE_MICROCOMPACT": "true",
    "ENABLE_TOOL_SEARCH": "true"
  },
  "includeCoAuthoredBy": true,
  "permissions": {
    "allow": [
      "Read",
      "Bash(pnpm:*)",
      "Bash(gh issue view:*)",
      "Bash(gh issue list:*)",
      "Bash(gh issue status:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr checks:*)",
      "Bash(gh pr review:*)",
      "Bash(gh pr status:*)",
      "Bash(gh label list)",
      "Bash(gh auth status:*)",
      "Bash(gh pr edit --add-label:*)",
      "Bash(gh repo view:*)",
      "Bash(gh run list:*)",
      "Bash(gh run view:*)",
      "Bash(gh workflow list:*)",
      "Bash(gh workflow view:*)",
      "Bash(gh release list:*)",
      "Bash(gh release view:*)",
      "Bash(git add:*)",
      "Bash(git mv:*)",
      "Bash(git commit:*)",
      "Bash(git fetch:*)",
      "Bash(git checkout -b:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git status:*)",
      "Bash(git branch:*)",
      "Bash(git show:*)",
      "Bash(git ls-tree:*)",
      "Bash(git ls-files:*)",
      "Bash(git rev-parse:*)",
      "Bash(git wt:*)",
      "Bash(git stash list:*)",
      "Bash(git show-branch:*)",
      "Bash(git merge-base:*)",
      "Bash(git cat-file:*)",
      "Bash(git shortlog:*)",
      "Bash(git describe:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(fd:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(awk:*)",
      "Bash(sed:*)",
      "Bash(jq:*)",
      "Bash(wc:*)",
      "Bash(sort:*)",
      "Bash(uniq:*)",
      "Bash(echo:*)",
      "Bash(printf:*)",
      "Bash(date:*)",
      "Bash(pwd:*)",
      "Bash(which:*)",
      "Bash(type:*)",
      "Bash(cd:*)",
      "Bash(xargs:*)",
      "Bash(cut:*)",
      "Bash(tr:*)",
      "Bash(diff:*)",
      "Bash(uname:*)",
      "Bash(ps:*)",
      "Bash(df:*)",
      "Bash(du:*)",
      "Bash(env)",
      "Bash(git remote:*)",
      "Bash(git blame:*)",
      "Bash(git config --list:*)",
      "Bash(gh api:*)",
      "Bash(npm view:*)",
      "Bash(npm info:*)",
      "Bash(npm audit:*)",
      "Bash(npm list:*)",
      "Bash(pnpm list:*)",
      "Bash(pnpm why:*)",
      "WebSearch",
      "mcp__container-use__environment_file_read",
      "mcp__container-use__environment_file_list",
      "mcp__container-use__environment_run_cmd",
      "mcp__figma-desktop__get_metadata",
      "mcp__figma-desktop__get_screenshot",
      "mcp__figma-desktop__get_design_context"
    ],
    "deny": [
      "Read(**/.env)"
    ]
  }
}
